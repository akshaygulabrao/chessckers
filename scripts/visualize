#!/usr/bin/env bash
# visualize — generate a self-contained HTML viewer for NN-vs-random games
#             and open it in your default browser.
#
# Usage:
#   ./scripts/visualize                  # 4 games at 200 sims, default weights
#   ./scripts/visualize --games 8        # any flag is passed through to make_spectate_html.py
#   ./scripts/visualize --weights runs/local-001/checkpoints/step_00010000.pt
#
# Defaults (overridable via env or CLI):
#   GAMES   (default 4)        --games
#   SIMS    (default 200)      --sims
#   TEMP    (default 0.5)      --temperature
#   OUT     (default spectate.html in repo root)
#   WEIGHTS (default runs/local-001/weights.pt)
set -euo pipefail

# Resolve repo root from script location so this works no matter where it's invoked.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENGINE_DIR="$REPO_ROOT/engine"

GAMES="${GAMES:-4}"
SIMS="${SIMS:-200}"
TEMP="${TEMP:-0.5}"
OUT="${OUT:-$REPO_ROOT/spectate.html}"
WEIGHTS="${WEIGHTS:-runs/local-001/weights.pt}"

cd "$ENGINE_DIR"

echo "[visualize] generating $GAMES game(s) at $SIMS sims (temp=$TEMP)…"
uv run python bench/make_spectate_html.py \
  --weights "$WEIGHTS" \
  --games "$GAMES" \
  --sims "$SIMS" \
  --temperature "$TEMP" \
  --out "$OUT" \
  "$@"

echo "[visualize] opening $OUT"
open "$OUT"
