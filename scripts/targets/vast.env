# Vast.ai cloud GPU box. MODE=workers_only — pure inference farm; trainer
# runs locally and weights sync up. HOST/PORT come from CLI per-instance:
#   scripts/launch_workers.sh vast <ssh_host> <ssh_port>
#
# pytorch/pytorch:2.5.0-cuda12.1-cudnn9-runtime puts torch in /opt/conda's
# system Python (no /venv/main, no uv). USE_PIP=1 tells the launcher to use
# plain `pip install -e .` — pip sees existing torch / httpx / chess /
# numpy and skips them, only registering our package.
MODE=workers_only
USER=root
REMOTE_BARE=/root/chessckers.git
WORK_DIR=/root/chessckers
PYTHON_BIN=/opt/conda/bin/python3
USE_PIP=1
RUN_DIR=/root/run
N_WORKERS=24
WID_BASE=200
DEVICE=cuda
SIMS=100
SEED=2000
SHARED_INFERENCE_FLAGS="--shared-inference --shared-max-batch-size 64 --shared-timeout-ms 5"
PRUNER_KEEP=500
