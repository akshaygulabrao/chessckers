# Vast.ai cloud GPU box. MODE=workers_only — pure inference farm; trainer
# runs locally and weights sync up. HOST/PORT come from launch_all.sh,
# which resolves them from the instance ID via `vastai ssh-url` — always
# direct (public_ipaddr + direct_port_end), never the proxy.
#
# Upstream pytorch/pytorch image (e.g. pytorch:2.5.0-cuda12.1-cudnn9-runtime)
# puts torch in conda at /opt/conda. USE_PIP=1 tells the launcher to use plain
# `pip install -e .` against that env — pip sees existing torch (and numpy,
# httpx, chess) and skips them; only registers our package.
# (Vast's custom vastai/pytorch template uses /venv/main instead — swap
# PYTHON_BIN if you bid on a box with that image.)
MODE=workers_only
USER=root
REMOTE_BARE=/root/chessckers.git
WORK_DIR=/root/chessckers
PYTHON_BIN=/opt/conda/bin/python3
USE_PIP=1
RUN_DIR=/root/run
# N_WORKERS=auto: launcher probes cgroup CPU quota on the box and sets
# workers = effective_cores - RESERVE_CORES. nproc lies on vast (returns
# host count, not what we paid for); cgroup is truth.
N_WORKERS=auto
RESERVE_CORES=2
WID_BASE=200
# Per-worker CPU mode: each worker holds its own model copy in its own
# process and runs forwards locally. Drops the shared-inference IPC
# round-trip (mp.Queue serialization + CUDA H2D/D2H + context switches)
# that was the actual bottleneck — workers were spending most of their
# time in futex_wait on the response queue, not in MCTS. The 3060 sits
# idle but it wasn't doing useful work anyway (~14ms GPU per 58ms batch).
DEVICE=cpu
SIMS=100
SEED=2000
SHARED_INFERENCE_FLAGS=""
PRUNER_KEEP=500
