# Vast.ai cloud GPU box. MODE=workers_only — pure inference farm; trainer
# runs locally and weights sync up. HOST/PORT come from launch_all.sh,
# which resolves them from the instance ID via `vastai ssh-url` — always
# direct (public_ipaddr + direct_port_end), never the proxy.
#
# PyTorch (Vast) template (image: vastai/pytorch) puts torch in
# /venv/main (Python 3.12 + cuda13). USE_PIP=1 tells the launcher to use
# plain `pip install -e .` against that venv — pip sees existing torch
# (and httpx/numpy) and skips them; only pulls chess + our package.
MODE=workers_only
USER=root
REMOTE_BARE=/root/chessckers.git
WORK_DIR=/root/chessckers
PYTHON_BIN=/venv/main/bin/python3
USE_PIP=1
RUN_DIR=/root/run
N_WORKERS=24
WID_BASE=200
DEVICE=cuda
SIMS=100
SEED=2000
SHARED_INFERENCE_FLAGS="--shared-inference --shared-max-batch-size 64 --shared-timeout-ms 5"
PRUNER_KEEP=500
