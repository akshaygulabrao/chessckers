# Local Mac (dev box). MODE=bundled = trainer + workers in one process
# (selfplay_az_async). HOST=local short-circuits all SSH/git push steps.
HOST=local
MODE=bundled
WORK_DIR=/Users/ox/AAworkspace/chessckers
VENV_DIR=/Users/ox/AAworkspace/chessckers/engine/.venv
RUN_DIR=/Users/ox/AAworkspace/chessckers/engine/runs/local-006
N_WORKERS=1
WID_BASE=100
DEVICE=mps
SIMS=100
SEED=2000
SHARED_INFERENCE_FLAGS=""
RUN_SECONDS=86400
# Game-based termination — stop at this many lifetime games across workers.
# Whichever cap fires first (RUN_GAMES or RUN_SECONDS) wins. local-005's
# single MPS worker did ~3,000 games in 24h.
RUN_GAMES=3000
# Resume from the completed local-005 run's final checkpoint.
RESUME_FROM=/Users/ox/AAworkspace/chessckers/engine/runs/local-005/checkpoints/step_00249712_final.pt
# Extra args appended in bundled mode: heavier eval matrix pits the live
# model against random + 5 fixed snapshots from local-005 (10/30/50/70/90%
# of 249,712 steps). 6 opponents x 2 sides x 20 games = 240 games per cycle,
# so we widen --eval-every-seconds from 1800 -> 5400 (90 min).
EXTRA_BUNDLED_ARGS="--eval-every-seconds 5400 \
  --eval-opponent pct10=/Users/ox/AAworkspace/chessckers/engine/runs/local-005/checkpoints/step_00024000.pt \
  --eval-opponent pct30=/Users/ox/AAworkspace/chessckers/engine/runs/local-005/checkpoints/step_00074000.pt \
  --eval-opponent pct50=/Users/ox/AAworkspace/chessckers/engine/runs/local-005/checkpoints/step_00124000.pt \
  --eval-opponent pct70=/Users/ox/AAworkspace/chessckers/engine/runs/local-005/checkpoints/step_00174000.pt \
  --eval-opponent pct90=/Users/ox/AAworkspace/chessckers/engine/runs/local-005/checkpoints/step_00224000.pt"
