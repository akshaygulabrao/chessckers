# Local Mac (dev box). MODE=bundled = trainer + workers in one process
# (selfplay_az_async). HOST=local short-circuits all SSH/git push steps.
HOST=local
MODE=bundled
WORK_DIR=/Users/ox/AAworkspace/chessckers
VENV_DIR=/Users/ox/AAworkspace/chessckers/engine/.venv
RUN_DIR=/Users/ox/AAworkspace/chessckers/engine/runs/local-005
N_WORKERS=1
WID_BASE=100
DEVICE=mps
SIMS=100
SEED=1000
SHARED_INFERENCE_FLAGS=""
RUN_SECONDS=86400
# Optional: resume from a checkpoint (model + optimizer + step).
# RESUME_FROM=/Users/ox/AAworkspace/chessckers/engine/runs/local-004/checkpoints/step_NNNN.pt
