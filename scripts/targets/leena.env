# Leena's MacBook (M2, 8GB, LAN). MODE=workers_only — pure inference farm;
# trainer runs locally and weights sync up. uv will install torch (CPU
# wheel) on first launch since the box doesn't have it pre-baked.
HOST=192.168.68.183
MODE=workers_only
USER=leenagulabrao
PORT=22
REMOTE_BARE=/Users/leenagulabrao/chessckers.git
WORK_DIR=/Users/leenagulabrao/chessckers
VENV_DIR=/Users/leenagulabrao/chessckers/engine/.venv
RUN_DIR=/Users/leenagulabrao/chessckers/engine/run
N_WORKERS=4
WID_BASE=300
DEVICE=cpu
SIMS=100
SEED=3000
SHARED_INFERENCE_FLAGS=""
PRUNER_KEEP=500
