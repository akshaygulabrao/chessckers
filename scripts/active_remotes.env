# Active remote sidecars for the local training stack.
#
# Sourced by scripts/watchdog.sh and scripts/status.sh — defines which
# remote boxes the watchdog will keep alive (auto-restart cloud_sync_sidecar
# sessions for) and which boxes status.sh will probe over SSH.
#
# Format: ACTIVE_REMOTES+=("name|host|port|user|remote_run_dir")
#   - name      = tmux session name (e.g. sync_vast, sync_vast_<id>); MUST
#                 start with "sync_" so status.sh can recognize sync logs at
#                 /tmp/<name>.log.
#   - host      = SSH hostname or IP.
#   - port      = SSH port.
#   - user      = SSH user.
#   - remote_run_dir = path on the remote that contains buffer/ + heartbeats/.
#
# After bidding a vast.ai instance, uncomment its line and edit host/port.
# When a remote is destroyed, comment its line back out.

ACTIVE_REMOTES=()

# Examples (uncomment + edit when active):
# ACTIVE_REMOTES+=("sync_vast|220.82.52.202|52232|root|/root/run")
# ACTIVE_REMOTES+=("sync_vast_45390|1.2.3.4|33445|root|/root/run")
