#!/usr/bin/env bash
# Shared fleet config — the SINGLE source of truth for the self-play CLIENT shape, sourced
# by launch_server.sh (server side: arch only), launch_local.sh (loopback) AND
# launch_fleet_leena.sh (LAN). Anything that must be IDENTICAL on every box lives here so
# local and leena can't drift; box-specific bits (server URL, client-id, worker-id-base,
# --update-cmd) stay in each launcher.
#
# Tunable self-play params (sims/temperature/noise) are deliberately NOT here — they ship
# LIVE from the server: run/selfplay.json rides each POST /next_game `train` job and the
# worker applies it per game. FLEET_SIMS_FALLBACK below is only a box's pre-server default.

# arch — MUST match the trainer (train_continuous in launch_local.sh).
FLEET_DH=256                 # --d-hidden
FLEET_CF=96                  # --c-filters
FLEET_NB=4                   # --n-blocks
FLEET_MAX_PLIES=200
FLEET_DEVICE=cpu
FLEET_WORKERS=4
FLEET_SIMS_FALLBACK=100      # client --sims; governs only the first game(s) before /selfplay mirrors in
FLEET_WEIGHTS_POLL_S=20      # workers re-check weights.pt mtime this often
FLEET_POLL_S=15              # client server-poll cadence

# Per-box self-play env shared by every client. Call after sourcing.
fleet_export_env() {
  export CHESSCKERS_MAX_PLIES="$FLEET_MAX_PLIES" CHESSCKERS_VALUE_DISCOUNT=0.98 \
         OMP_NUM_THREADS=1 MKL_NUM_THREADS=1 VECLIB_MAXIMUM_THREADS=1
}

# ';'-joined seed FENs from a seed_mix.txt (new_game samples one per game). $1 = file path.
fleet_seed_fens() {
  grep -vE '^[[:space:]]*(#|$)' "$1" | paste -sd ';' -
}
